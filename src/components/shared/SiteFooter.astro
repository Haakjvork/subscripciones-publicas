---
import SiteLink from "../ui/SiteLink.astro";
---

<footer>
	<p class="footer-copy">Mockup inicial en Astro. Listo para que cambies los porcentajes y las partidas del desglose en una siguiente iteración.</p>
	<nav class="footer-links" aria-label="Enlaces de pie">
		<SiteLink href="/about" variant="secondary">About</SiteLink>
	</nav>
</footer>

<style>
	footer {
		border: 1px solid var(--line);
		border-radius: 20px;
		background: rgb(253 250 243 / 86%);
		backdrop-filter: blur(6px);
		box-shadow: var(--shadow);
		margin-top: 1rem;
		padding: 0.9rem 1.2rem;
		font-size: 0.9rem;
		color: var(--ink-soft);
	}

	.footer-copy {
		margin: 0;
	}

	.footer-links {
		margin-top: 0.5rem;
		display: flex;
		gap: 0.6rem;
	}
</style>
