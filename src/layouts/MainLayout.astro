---
import SiteHeader from "../components/shared/SiteHeader.astro";
import SiteFooter from "../components/shared/SiteFooter.astro";
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Calculadora Fiscal" } = Astro.props;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<SiteHeader />
			<main>
				<slot />
			</main>
			<SiteFooter />
		</div>
		<slot name="scripts" />
	</body>
</html>

<style>
	.site-shell {
		width: min(1100px, 92vw);
		margin: 0 auto;
		padding: 1rem 0 2.5rem;
	}

	main {
		display: grid;
		gap: 1rem;
	}

	.hero {
		padding: 1.6rem 1.2rem;
		border-radius: 24px;
		background:
			linear-gradient(130deg, rgb(20 95 107 / 14%), rgb(218 90 42 / 20%)),
			var(--bg-soft);
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
		animation: rise 0.6s ease both;
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(1.65rem, 3vw, 2.6rem);
		line-height: 1.15;
	}

	.hero p {
		margin: 0.8rem 0 0;
		max-width: 65ch;
		color: var(--ink-soft);
	}

	.panel {
		background: var(--bg-soft);
		border: 1px solid var(--line);
		border-radius: 24px;
		padding: 1.2rem;
		box-shadow: var(--shadow);
		animation: rise 0.7s ease both;
	}

	.about-panel {
		display: grid;
		gap: 1rem;
	}
</style>
